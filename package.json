{
  "name": "vscode-english-coach",
  "displayName": "English Coach 英语口语教练",
  "description": "Qwen 通义千问 / DeepSeek / MiniMax 海螺 / 小米 MiMo / Gemini / GPT 驱动的英语口语教练:把你的英文改写成地道表达并用中文讲解,边写提示词边练口语,支持朗读(TTS)。Rewrite English into natural, native-sounding phrasing with Chinese explanations — powered by Qwen, DeepSeek, MiniMax, MiMo, Gemini, OpenAI.",
  "version": "0.1.1",
  "keywords": [
    "english",
    "英语",
    "口语",
    "英语口语",
    "地道英语",
    "english coach",
    "英语教练",
    "口语练习",
    "改写",
    "润色",
    "翻译",
    "translate",
    "qwen",
    "通义千问",
    "dashscope",
    "deepseek",
    "minimax",
    "海螺",
    "mimo",
    "小米",
    "xiaomi",
    "gemini",
    "gpt",
    "openai",
    "chatgpt",
    "byok",
    "tts",
    "朗读",
    "copilot",
    "vibe coding"
  ],
  "icon": "media/icon.png",
  "publisher": "xianwei-zhang",
  "license": "MIT",
  "author": "Xianwei Zhang",
  "repository": {
    "type": "git",
    "url": "https://github.com/xwzhangSZU/vscode-english-coach.git"
  },
  "bugs": {
    "url": "https://github.com/xwzhangSZU/vscode-english-coach/issues"
  },
  "homepage": "https://github.com/xwzhangSZU/vscode-english-coach#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Education",
    "Chat",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "englishCoach",
          "title": "English Coach",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "englishCoach": [
        { "id": "englishCoach.sidebar", "name": "Coach", "type": "webview" },
        { "id": "englishCoach.history", "name": "Recent", "type": "tree" }
      ]
    },
    "commands": [
      {
        "command": "englishCoach.setApiKey",
        "title": "English Coach: Set API Key"
      },
      {
        "command": "englishCoach.coachClipboard",
        "title": "English Coach: Coach Clipboard Now"
      },
      {
        "command": "englishCoach.focus",
        "title": "English Coach: Open Sidebar"
      },
      { "command": "englishCoach.history.reload", "title": "English Coach: Reload History Entry" },
      { "command": "englishCoach.history.copyOutput", "title": "Copy Native Version", "icon": "$(copy)" },
      { "command": "englishCoach.history.delete", "title": "Delete", "icon": "$(trash)" },
      { "command": "englishCoach.history.clear", "title": "English Coach: Clear History", "icon": "$(clear-all)" },
      { "command": "englishCoach.reviewDeck", "title": "English Coach: Review Deck 复习错题本", "icon": "$(mortar-board)" },
      { "command": "englishCoach.history.star", "title": "Star / Unstar", "icon": "$(star)" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "englishCoach.history.reload", "when": "false" },
        { "command": "englishCoach.history.copyOutput", "when": "false" },
        { "command": "englishCoach.history.delete", "when": "false" },
        { "command": "englishCoach.history.star", "when": "false" }
      ],
      "view/title": [
        { "command": "englishCoach.reviewDeck", "when": "view == englishCoach.history", "group": "navigation" },
        { "command": "englishCoach.history.clear", "when": "view == englishCoach.history", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "englishCoach.history.star", "when": "view == englishCoach.history && viewItem == historyEntry", "group": "inline" },
        { "command": "englishCoach.history.copyOutput", "when": "view == englishCoach.history && viewItem == historyEntry", "group": "inline" },
        { "command": "englishCoach.history.delete", "when": "view == englishCoach.history && viewItem == historyEntry", "group": "inline" }
      ]
    },
    "chatParticipants": [
      {
        "id": "englishCoach.coach",
        "name": "coach",
        "fullName": "English Coach",
        "description": "Rewrite into idiomatic English — or use /translate",
        "isSticky": true,
        "commands": [
          { "name": "translate", "description": "Translate to idiomatic English (or another language)" }
        ]
      }
    ],
    "configuration": {
      "title": "English Coach",
      "properties": {
        "englishCoach.defaultProvider": {
          "type": "string",
          "enum": ["qwen", "minimax", "deepseek", "mimo", "gemini", "openai"],
          "default": "qwen",
          "description": "Provider used by default and listed first."
        },
        "englishCoach.providerOrder": {
          "type": "string",
          "default": "qwen,minimax,deepseek,mimo,gemini,openai",
          "description": "Comma-separated provider order shown in the switcher."
        },
        "englishCoach.modelTier": {
          "type": "string",
          "enum": ["fast", "pro", "custom"],
          "default": "pro",
          "description": "Which model tier to use. Custom uses each provider's Model setting."
        },
        "englishCoach.requestTimeoutSeconds": { "type": "number", "default": 45 },
        "englishCoach.maxOutputTokens": { "type": "number", "default": 4096 },
        "englishCoach.qwen.enabled": { "type": "boolean", "default": true },
        "englishCoach.qwen.baseURL": { "type": "string", "default": "https://dashscope.aliyuncs.com/compatible-mode/v1" },
        "englishCoach.qwen.model": { "type": "string", "default": "qwen-plus" },
        "englishCoach.deepseek.enabled": { "type": "boolean", "default": true },
        "englishCoach.deepseek.baseURL": { "type": "string", "default": "https://api.deepseek.com/anthropic" },
        "englishCoach.deepseek.model": { "type": "string", "default": "deepseek-v4-flash" },
        "englishCoach.mimo.enabled": { "type": "boolean", "default": true },
        "englishCoach.mimo.baseURL": { "type": "string", "default": "https://token-plan-cn.xiaomimimo.com/v1" },
        "englishCoach.mimo.model": { "type": "string", "default": "mimo-v2.5-pro" },
        "englishCoach.gemini.enabled": { "type": "boolean", "default": false },
        "englishCoach.gemini.baseURL": { "type": "string", "default": "https://generativelanguage.googleapis.com/v1beta" },
        "englishCoach.gemini.model": { "type": "string", "default": "gemini-3.5-flash" },
        "englishCoach.minimax.enabled": { "type": "boolean", "default": true },
        "englishCoach.minimax.baseURL": { "type": "string", "default": "https://api.minimaxi.com/anthropic" },
        "englishCoach.minimax.model": { "type": "string", "default": "MiniMax-M2.7-highspeed" },
        "englishCoach.openai.enabled": { "type": "boolean", "default": false },
        "englishCoach.openai.baseURL": { "type": "string", "default": "https://api.openai.com/v1" },
        "englishCoach.openai.model": { "type": "string", "default": "gpt-4.1-mini" },
        "englishCoach.tts.provider": { "type": "string", "enum": ["qwen", "gemini", "mimo", "minimax"], "default": "qwen" },
        "englishCoach.tts.qwenModel": { "type": "string", "default": "qwen3-tts-flash" },
        "englishCoach.tts.qwenVoice": { "type": "string", "default": "Cherry" },
        "englishCoach.tts.qwenLanguageType": { "type": "string", "default": "Auto" },
        "englishCoach.tts.qwenBaseURL": { "type": "string", "default": "https://dashscope.aliyuncs.com/api/v1" },
        "englishCoach.tts.qwenInstructions": { "type": "string", "default": "" },
        "englishCoach.tts.geminiVoice": { "type": "string", "default": "Kore" },
        "englishCoach.tts.mimoModel": { "type": "string", "default": "mimo-v2.5-tts" },
        "englishCoach.tts.mimoVoice": { "type": "string", "default": "Chloe" },
        "englishCoach.tts.minimaxBaseURL": { "type": "string", "default": "https://api.minimaxi.com/v1" },
        "englishCoach.tts.minimaxModel": { "type": "string", "default": "speech-2.8-turbo" },
        "englishCoach.tts.minimaxVoiceId": { "type": "string", "default": "male-qn-qingse" },
        "englishCoach.clipboardWatch.minLength": { "type": "number", "default": 12 }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
